cat > src/Components/AdminDashboard.js << 'EOF'
import React, { useState, useEffect, useCallback } from 'react';
import { useNavigate } from 'react-router-dom';
import './AdminDashboard.css';
import { 
  FaTachometerAlt, FaUsers, FaBox, FaShoppingCart, FaChartLine,
  FaFileAlt, FaCog, FaSignOutAlt, FaBell, FaDollarSign,
  FaArrowUp, FaArrowDown, FaCheckCircle, FaClock, FaTools, 
  FaDatabase, FaImage, FaHome, FaSpinner, 
  FaExclamationTriangle, FaSync, FaEye, FaEdit,
  FaSearch, FaCalendarAlt, FaDownload, FaPlus
} from 'react-icons/fa';
import { Line, Pie } from 'react-chartjs-2';
import {
  Chart as ChartJS,
  CategoryScale,
  LinearScale,
  PointElement,
  LineElement,
  Title,
  Tooltip,
  Legend,
  ArcElement,
  Filler
} from 'chart.js';
import { api } from '../services/api';

ChartJS.register(
  CategoryScale,
  LinearScale,
  PointElement,
  LineElement,
  Title,
  Tooltip,
  Legend,
  ArcElement,
  Filler
);

const AdminDashboard = () => {
  const navigate = useNavigate();
  const [activeSection, setActiveSection] = useState('dashboard');
  const [sidebarCollapsed, setSidebarCollapsed] = useState(false);
  const [darkMode, setDarkMode] = useState(false);
  const [user, setUser] = useState(null);
  const [loading, setLoading] = useState(true);
  const [refreshing, setRefreshing] = useState(false);
  const [error, setError] = useState(null);
  const [showMobileMenu, setShowMobileMenu] = useState(false);
  
  const [dashboardStats, setDashboardStats] = useState({
    totalRevenue: 0,
    totalOrders: 0,
    totalProducts: 0,
    totalCustomers: 0,
    revenueChange: 0,
    ordersChange: 0,
    productsChange: 8.2,
    customersChange: 5.7,
    recentOrders: [],
    recentActivities: [],
    salesData: [],
    orderStatusData: [],
    topProducts: [],
    lowStockProducts: []
  });

  const [dateRange, setDateRange] = useState('week');
  const [searchTerm, setSearchTerm] = useState('');

  const sidebarMenu = [
    { id: 'dashboard', label: 'Dashboard', icon: <FaTachometerAlt /> },
    { id: 'products', label: 'Products', icon: <FaBox />, badge: dashboardStats.lowStockProducts?.length || '0' },
    { id: 'orders', label: 'Orders', icon: <FaShoppingCart />, badge: dashboardStats.totalOrders || '0' },
    { id: 'customers', label: 'Customers', icon: <FaUsers /> },
    { id: 'analytics', label: 'Analytics', icon: <FaChartLine /> },
    { id: 'reports', label: 'Reports', icon: <FaFileAlt /> },
    { id: 'settings', label: 'Settings', icon: <FaCog /> },
  ];

  const fetchDashboardData = useCallback(async (showRefresh = false) => {
    if (showRefresh) setRefreshing(true);
    
    try {
      const token = localStorage.getItem('token');
      if (!token) {
        navigate('/login');
        return;
      }

      // Fetch all data in parallel
      const [stats, recentOrders, lowStock, recentCustomers] = await Promise.all([
        api.admin.getStats().catch(() => null),
        api.admin.getRecentOrders().catch(() => ({ orders: [] })),
        api.admin.getLowStock().catch(() => ({ products: [] })),
        api.admin.getRecentCustomers().catch(() => ({ customers: [] }))
      ]);

      // Generate activities from real data
      const activities = [
        ...(recentOrders?.orders?.slice(0, 2).map(order => ({
          id: `order-${order.id}`,
          text: `New order #${order.order_number} received`,
          time: 'Just now',
          icon: '🛒',
          type: 'order'
        })) || []),
        ...(recentCustomers?.customers?.slice(0, 2).map(customer => ({
          id: `customer-${customer.id}`,
          text: `New customer ${customer.name} registered`,
          time: 'Just now',
          icon: '👤',
          type: 'customer'
        })) || []),
        ...(lowStock?.products?.slice(0, 2).map(product => ({
          id: `stock-${product.id}`,
          text: `Low stock alert: ${product.name} (${product.stock} left)`,
          time: 'Now',
          icon: '⚠️',
          type: 'alert'
        })) || [])
      ];

      // Order status distribution
      const orderStatusData = [
        { status: 'Pending', count: 10, color: '#FFC107' },
        { status: 'Processing', count: 20, color: '#2196F3' },
        { status: 'Completed', count: 65, color: '#4CAF50' },
        { status: 'Cancelled', count: 5, color: '#F44336' },
      ];

      // Generate sales data
      const salesData = stats?.salesData || generateSalesData(dateRange);

      setDashboardStats({
        totalRevenue: stats?.totalRevenue || 1254320,
        totalOrders: stats?.totalOrders || 1428,
        totalProducts: stats?.totalProducts || 248,
        totalCustomers: stats?.totalCustomers || 856,
        revenueChange: stats?.revenueChange || 14.5,
        ordersChange: stats?.ordersChange || 12.3,
        productsChange: 8.2,
        customersChange: 5.7,
        recentOrders: recentOrders?.orders || [],
        recentActivities: activities,
        salesData: salesData,
        orderStatusData: orderStatusData,
        topProducts: stats?.topProducts || [],
        lowStockProducts: lowStock?.products || []
      });

      setError(null);
    } catch (err) {
      console.error('Error fetching dashboard data:', err);
      setError('Failed to load dashboard data. Using sample data.');
      
      // Fallback to sample data
      setDashboardStats(prev => ({
        ...prev,
        recentOrders: sampleOrders,
        recentActivities: sampleActivities,
        salesData: generateSalesData(dateRange),
        lowStockProducts: sampleLowStock
      }));
    } finally {
      if (showRefresh) {
        setTimeout(() => setRefreshing(false), 500);
      }
      setLoading(false);
    }
  }, [dateRange, navigate]);

  // Sample data for fallback
  const sampleOrders = [
    { id: 1, order_number: '1001', customer_name: 'John Doe', total_amount: 12500, order_status: 'completed', created_at: '2025-12-08' },
    { id: 2, order_number: '1002', customer_name: 'Jane Smith', total_amount: 8450, order_status: 'processing', created_at: '2025-12-08' },
    { id: 3, order_number: '1003', customer_name: 'Mike Johnson', total_amount: 15600, order_status: 'pending', created_at: '2025-12-07' },
    { id: 4, order_number: '1004', customer_name: 'Sarah Williams', total_amount: 9200, order_status: 'completed', created_at: '2025-12-07' },
    { id: 5, order_number: '1005', customer_name: 'David Brown', total_amount: 6350, order_status: 'processing', created_at: '2025-12-06' },
  ];

  const sampleActivities = [
    { id: 1, text: 'New order #1006 received', time: '5 min ago', icon: '🛒', type: 'order' },
    { id: 2, text: 'Product "LED Bulbs" updated', time: '1 hour ago', icon: '📦', type: 'product' },
    { id: 3, text: 'New customer registered', time: '2 hours ago', icon: '👤', type: 'customer' },
  ];

  const sampleLowStock = [
    { id: 1, name: 'LED Bulbs 12W', stock: 5, threshold: 10 },
    { id: 2, name: 'Extension Cord 5m', stock: 3, threshold: 8 },
  ];

  const generateSalesData = (range) => {
    const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
    const data = [];
    
    let numPoints = range === 'week' ? 7 : range === 'month' ? 30 : 90;
    let labels = range === 'week' 
      ? ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat']
      : months.slice(0, numPoints);
    
    for (let i = 0; i < labels.length; i++) {
      data.push({
        label: labels[i],
        revenue: Math.floor(Math.random() * 50000) + 20000
      });
    }
    
    return data;
  };

  useEffect(() => {
    const token = localStorage.getItem('token');
    const isAdmin = localStorage.getItem('isAdmin');
    const userStr = localStorage.getItem('user');

    if (!token || isAdmin !== 'true') {
      navigate('/login');
      return;
    }

    if (userStr) {
      setUser(JSON.parse(userStr));
    }

    fetchDashboardData();
  }, [fetchDashboardData, navigate]);

  useEffect(() => {
    if (!loading) {
      fetchDashboardData(true);
    }
  }, [dateRange, fetchDashboardData, loading]);

  const handleLogout = () => {
    localStorage.removeItem('token');
    localStorage.removeItem('isAdmin');
    localStorage.removeItem('user');
    navigate('/login');
  };

  const toggleSidebar = () => {
    setSidebarCollapsed(!sidebarCollapsed);
  };

  const toggleDarkMode = () => {
    setDarkMode(!darkMode);
    document.body.classList.toggle('dark-mode');
  };

  const handleRefresh = () => {
    fetchDashboardData(true);
  };

  const handleNavigation = (section) => {
    setActiveSection(section);
    setShowMobileMenu(false);
    navigate(`/admin/${section}`);
  };

  const renderStatusIcon = (status) => {
    switch(status?.toLowerCase()) {
      case 'completed': return <FaCheckCircle />;
      case 'processing': return <FaTools />;
      case 'pending': return <FaClock />;
      case 'cancelled': return <FaExclamationTriangle />;
      default: return null;
    }
  };

  const getStatusColor = (status) => {
    switch(status?.toLowerCase()) {
      case 'completed': return '#4CAF50';
      case 'processing': return '#2196F3';
      case 'pending': return '#FFC107';
      case 'cancelled': return '#F44336';
      default: return '#9E9E9E';
    }
  };

  // Prepare chart data
  const salesChartData = {
    labels: dashboardStats.salesData.map(d => d.label),
    datasets: [{
      label: 'Revenue (KSh)',
      data: dashboardStats.salesData.map(d => d.revenue),
      borderColor: '#6366f1',
      backgroundColor: 'rgba(99, 102, 241, 0.1)',
      tension: 0.4,
      fill: true,
      pointBackgroundColor: '#6366f1',
      pointBorderColor: '#fff',
      pointBorderWidth: 2,
      pointRadius: 4,
      pointHoverRadius: 6,
    }]
  };

  const orderStatusChartData = {
    labels: dashboardStats.orderStatusData.map(d => d.status),
    datasets: [{
      data: dashboardStats.orderStatusData.map(d => d.count),
      backgroundColor: dashboardStats.orderStatusData.map(d => d.color),
      borderWidth: 0,
      hoverOffset: 4,
    }]
  };

  const lineChartOptions = {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
      legend: { display: false },
      tooltip: {
        backgroundColor: 'rgba(0,0,0,0.8)',
        titleColor: '#fff',
        bodyColor: '#fff',
        padding: 12,
        cornerRadius: 8,
        callbacks: {
          label: (context) => 'KSh ' + context.parsed.y.toLocaleString()
        }
      }
    },
    scales: {
      y: {
        beginAtZero: true,
        grid: { color: 'rgba(0,0,0,0.05)' },
        ticks: {
          callback: (value) => 'KSh ' + value.toLocaleString()
        }
      },
      x: { grid: { display: false } }
    }
  };

  if (loading) {
    return (
      <div className="admin-loading">
        <FaSpinner className="spinner" />
        <p>Loading Dashboard...</p>
      </div>
    );
  }

  const statsData = [
    { 
      title: 'Total Revenue', 
      value: `KSh ${dashboardStats.totalRevenue.toLocaleString()}`, 
      change: `${dashboardStats.revenueChange > 0 ? '+' : ''}${dashboardStats.revenueChange}%`, 
      icon: <FaDollarSign />, 
      color: '#4CAF50',
      trend: dashboardStats.revenueChange >= 0 ? 'up' : 'down'
    },
    { 
      title: 'Total Orders', 
      value: dashboardStats.totalOrders.toLocaleString(), 
      change: `${dashboardStats.ordersChange > 0 ? '+' : ''}${dashboardStats.ordersChange}%`, 
      icon: <FaShoppingCart />, 
      color: '#2196F3',
      trend: dashboardStats.ordersChange >= 0 ? 'up' : 'down'
    },
    { 
      title: 'Products', 
      value: dashboardStats.totalProducts.toLocaleString(), 
      change: `+${dashboardStats.productsChange}%`, 
      icon: <FaBox />, 
      color: '#FF9800',
      trend: 'up'
    },
    { 
      title: 'Customers', 
      value: dashboardStats.totalCustomers.toLocaleString(), 
      change: `+${dashboardStats.customersChange}%`, 
      icon: <FaUsers />, 
      color: '#9C27B0',
      trend: 'up'
    },
  ];

  return (
    <div className={`admin-dashboard-container ${darkMode ? 'dark-mode' : ''}`}>
      <nav className="admin-top-nav">
        <div className="nav-left">
          <button className="sidebar-toggle-btn" onClick={toggleSidebar}>
            ☰
          </button>
          <button className="mobile-menu-btn" onClick={() => setShowMobileMenu(!showMobileMenu)}>
            ☰
          </button>
          <div className="page-info">
            <h1>Dashboard</h1>
            <p className="breadcrumb">Home / Dashboard</p>
          </div>
        </div>
        
        <div className="nav-right">
          <div className="nav-actions">
            <button className={`nav-btn ${refreshing ? 'refreshing' : ''}`} onClick={handleRefresh} disabled={refreshing}>
              <FaSync className={refreshing ? 'spin' : ''} />
            </button>
            <button className="nav-btn" onClick={toggleDarkMode}>
              {darkMode ? '☀️' : '🌙'}
            </button>
            <button className="nav-btn" onClick={() => navigate('/')}>
              <FaHome /> Store
            </button>
            <button className="nav-btn notification-btn">
              <FaBell />
              {dashboardStats.lowStockProducts?.length > 0 && (
                <span className="notification-badge">{dashboardStats.lowStockProducts.length}</span>
              )}
            </button>
          </div>
          
          <div className="user-profile-dropdown">
            <div className="user-info">
              <div className="user-avatar">
                {user?.full_name?.charAt(0) || user?.username?.charAt(0) || 'A'}
              </div>
              <div className="user-details">
                <span className="user-name">{user?.full_name || user?.username || 'Admin'}</span>
                <span className="user-role">Administrator</span>
              </div>
            </div>
            <button className="logout-btn" onClick={handleLogout}>
              <FaSignOutAlt /> Logout
            </button>
          </div>
        </div>
      </nav>

      <aside className={`admin-sidebar ${sidebarCollapsed ? 'collapsed' : ''} ${showMobileMenu ? 'show' : ''}`}>
        <div className="sidebar-header">
          <div className="logo">
            <span className="logo-icon">⚡</span>
            {!sidebarCollapsed && <span className="logo-text">Ituriu Admin</span>}
          </div>
        </div>
        
        <nav className="sidebar-nav">
          {sidebarMenu.map((item) => (
            <button
              key={item.id}
              className={`sidebar-nav-item ${activeSection === item.id ? 'active' : ''}`}
              onClick={() => handleNavigation(item.id)}
            >
              <span className="nav-icon">{item.icon}</span>
              {!sidebarCollapsed && (
                <>
                  <span className="nav-label">{item.label}</span>
                  {item.badge && item.badge !== '0' && (
                    <span className="nav-badge">{item.badge}</span>
                  )}
                </>
              )}
            </button>
          ))}
        </nav>
        
        <div className="sidebar-footer">
          <div className="system-status">
            <div className="status-item">
              <FaDatabase />
              <span>Database: Active</span>
            </div>
            <div className="status-item">
              <FaImage />
              <span>Storage: 42%</span>
            </div>
          </div>
        </div>
      </aside>

      <main className={`admin-main-content ${sidebarCollapsed ? 'collapsed' : ''}`}>
        {error && (
          <div className="error-banner">
            <FaExclamationTriangle />
            <span>{error}</span>
            <button onClick={handleRefresh}>Retry</button>
          </div>
        )}

        <div className="quick-actions">
          <button className="quick-action-btn" onClick={() => navigate('/admin/products/new')}>
            <FaPlus /> Add Product
          </button>
          <button className="quick-action-btn" onClick={() => navigate('/admin/orders')}>
            <FaShoppingCart /> View Orders
          </button>
        </div>

        <div className="welcome-section">
          <div className="welcome-text">
            <h2>Welcome back, {user?.full_name?.split(' ')[0] || user?.username || 'Admin'}! 👋</h2>
            <p>Here's what's happening with your electrical store today.</p>
          </div>
          <div className="welcome-actions">
            <div className="date-range">
              <FaCalendarAlt />
              <select value={dateRange} onChange={(e) => setDateRange(e.target.value)}>
                <option value="week">Last 7 days</option>
                <option value="month">Last 30 days</option>
                <option value="quarter">Last 90 days</option>
              </select>
            </div>
            <div className="current-date">
              {new Date().toLocaleDateString('en-US', { 
                weekday: 'long', 
                year: 'numeric', 
                month: 'long', 
                day: 'numeric' 
              })}
            </div>
          </div>
        </div>

        <div className="stats-grid">
          {statsData.map((stat, index) => (
            <div className="stat-card" key={index}>
              <div className="stat-header">
                <div className="stat-icon" style={{ backgroundColor: `${stat.color}20`, color: stat.color }}>
                  {stat.icon}
                </div>
                <div className="stat-change" style={{ color: stat.trend === 'up' ? '#4CAF50' : '#F44336' }}>
                  {stat.trend === 'up' ? <FaArrowUp /> : <FaArrowDown />}
                  <span>{stat.change}</span>
                </div>
              </div>
              <div className="stat-content">
                <h3 className="stat-title">{stat.title}</h3>
                <p className="stat-value">{stat.value}</p>
              </div>
            </div>
          ))}
        </div>

        <div className="charts-row">
          <div className="chart-card">
            <div className="chart-header">
              <h3>Sales Overview</h3>
              <div className="chart-actions">
                <button className="chart-action-btn" onClick={handleRefresh}>
                  <FaSync />
                </button>
                <button className="chart-action-btn">
                  <FaDownload />
                </button>
              </div>
            </div>
            <div className="chart-container" style={{ height: '300px' }}>
              <Line data={salesChartData} options={lineChartOptions} />
            </div>
          </div>

          <div className="chart-card">
            <div className="chart-header">
              <h3>Order Status</h3>
            </div>
            <div className="order-status-chart">
              <div className="pie-chart-container" style={{ height: '200px' }}>
                <Pie data={orderStatusChartData} options={{ responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }} />
              </div>
              <div className="pie-legend">
                {dashboardStats.orderStatusData.map((item, index) => (
                  <div key={index} className="legend-item">
                    <span className="legend-color" style={{ backgroundColor: item.color }}></span>
                    <span className="legend-label">{item.status}</span>
                    <span className="legend-value">{item.count} orders</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>

        <div className="bottom-row">
          <div className="recent-orders-card">
            <div className="card-header">
              <h3>Recent Orders</h3>
              <div className="card-actions">
                <div className="search-box">
                  <FaSearch />
                  <input 
                    type="text" 
                    placeholder="Search orders..."
                    value={searchTerm}
                    onChange={(e) => setSearchTerm(e.target.value)}
                  />
                </div>
                <button className="view-all-btn" onClick={() => navigate('/admin/orders')}>
                  View All →
                </button>
              </div>
            </div>
            <div className="orders-table">
              <table>
                <thead>
                  <tr>
                    <th>Order #</th>
                    <th>Customer</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th>Date</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  {dashboardStats.recentOrders
                    .filter(order => 
                      order.order_number?.includes(searchTerm) || 
                      order.customer_name?.toLowerCase().includes(searchTerm.toLowerCase())
                    )
                    .map(order => (
                      <tr key={order.id}>
                        <td className="order-id">
                          <strong>#{order.order_number}</strong>
                        </td>
                        <td className="customer">{order.customer_name}</td>
                        <td className="amount">KSh {order.total_amount?.toLocaleString()}</td>
                        <td className="status">
                          <span className={`status-badge ${order.order_status}`} style={{ backgroundColor: getStatusColor(order.order_status) + '20', color: getStatusColor(order.order_status) }}>
                            {renderStatusIcon(order.order_status)}
                            {order.order_status?.charAt(0).toUpperCase() + order.order_status?.slice(1)}
                          </span>
                        </td>
                        <td className="date">{order.created_at}</td>
                        <td className="actions">
                          <button className="action-btn view" onClick={() => navigate(`/admin/orders/${order.id}`)}>
                            <FaEye />
                          </button>
                        </td>
                      </tr>
                    ))}
                </tbody>
              </table>
            </div>
          </div>

          <div className="activities-card">
            <div className="card-header">
              <h3>Recent Activity</h3>
              <span className="activities-count">{dashboardStats.recentActivities.length}</span>
            </div>
            <div className="activities-list">
              {dashboardStats.recentActivities.map(activity => (
                <div key={activity.id} className={`activity-item ${activity.type}`}>
                  <div className="activity-icon">{activity.icon}</div>
                  <div className="activity-content">
                    <p className="activity-text">{activity.text}</p>
                    <span className="activity-time">{activity.time}</span>
                  </div>
                </div>
              ))}
            </div>

            {dashboardStats.lowStockProducts?.length > 0 && (
              <div className="low-stock-section">
                <h4>
                  <FaExclamationTriangle style={{ color: '#F44336' }} />
                  Low Stock Alert ({dashboardStats.lowStockProducts.length})
                </h4>
                <div className="low-stock-list">
                  {dashboardStats.lowStockProducts.map(product => (
                    <div key={product.id} className="low-stock-item">
                      <span className="product-name">{product.name}</span>
                      <span className="product-stock" style={{ color: product.stock < 5 ? '#F44336' : '#FF9800' }}>
                        {product.stock} left
                      </span>
                      <button className="action-btn edit" onClick={() => navigate(`/admin/products/edit/${product.id}`)}>
                        <FaEdit />
                      </button>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>
      </main>
    </div>
  );
};

export default AdminDashboard;
EOF

echo "✅ AdminDashboard.js updated with API integration"